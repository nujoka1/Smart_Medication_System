<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>MedSystem — Intelligent Dispensing</title>
<script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@500;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:       #080b10;
  --bg2:      #0d1117;
  --bg3:      #111820;
  --border:   #1a2332;
  --border2:  #243040;
  --text:     #cdd9e5;
  --muted:    #4a6278;
  --dim:      #1e2d3d;
  --green:    #39d98a;
  --green-d:  #0d2e1e;
  --amber:    #f5a623;
  --amber-d:  #2d1f06;
  --red:      #f07070;
  --red-d:    #2d0e0e;
  --blue:     #58a6ff;
  --blue-d:   #0d1f33;
  --purple:   #b48eff;
  --purple-d: #1a1033;
  --mono:     'DM Mono', monospace;
  --sans:     'Inter', sans-serif;
  --display:  'Syne', sans-serif;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  font-size: 14px;
  line-height: 1.5;
}

/* ── Scrollbar ── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

/* ── Layout ── */
.shell { display: flex; height: 100vh; overflow: hidden; }

/* ── Sidebar ── */
.sidebar {
  width: 220px; flex-shrink: 0;
  background: var(--bg2);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  padding: 0;
}
.logo {
  padding: 22px 20px 18px;
  border-bottom: 1px solid var(--border);
}
.logo-mark {
  font-family: var(--display);
  font-size: 17px; font-weight: 700;
  color: #fff; letter-spacing: -.3px;
  display: flex; align-items: center; gap: 8px;
}
.logo-icon {
  width: 28px; height: 28px; border-radius: 7px;
  background: linear-gradient(135deg, var(--green), #1a8a55);
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
}
.logo-sub { font-size: 10px; color: var(--muted); margin-top: 2px; font-family: var(--mono); letter-spacing: .05em; }

nav { padding: 12px 10px; flex: 1; }
.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 12px; border-radius: 8px;
  font-size: 13px; font-weight: 500; color: var(--muted);
  cursor: pointer; margin-bottom: 2px;
  transition: all .15s;
}
.nav-item:hover { background: var(--bg3); color: var(--text); }
.nav-item.active { background: var(--dim); color: var(--green); }
.nav-icon { font-size: 15px; width: 18px; text-align: center; }

.sys-info {
  padding: 14px 16px;
  border-top: 1px solid var(--border);
  font-family: var(--mono);
  font-size: 11px; color: var(--muted);
}
.sys-row { display: flex; justify-content: space-between; margin-bottom: 4px; }
.sys-val { color: var(--green); }
#dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%;
       background: var(--green); margin-right: 6px;
       animation: blink 2s ease-in-out infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

/* ── Main ── */
.main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

.topbar {
  height: 52px; flex-shrink: 0;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center;
  padding: 0 24px;
  justify-content: space-between;
  background: var(--bg2);
}
.page-title {
  font-family: var(--display);
  font-size: 15px; font-weight: 600; color: #fff;
}
#clock {
  font-family: var(--mono);
  font-size: 12px; color: var(--muted);
}

.content { flex: 1; overflow-y: auto; padding: 24px; }
.panel { display: none; }
.panel.active { display: block; }

/* ── Stat cards ── */
.cards { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; margin-bottom: 24px; }
.stat {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 10px; padding: 16px 18px;
  position: relative; overflow: hidden;
}
.stat::before {
  content: ''; position: absolute;
  top: 0; left: 0; right: 0; height: 2px;
}
.stat.s-green::before { background: var(--green); }
.stat.s-amber::before { background: var(--amber); }
.stat.s-red::before   { background: var(--red); }
.stat.s-blue::before  { background: var(--blue); }
.stat-lbl { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 8px; }
.stat-val { font-family: var(--display); font-size: 30px; font-weight: 700; color: #fff; line-height: 1; }
.stat.s-green .stat-val { color: var(--green); }
.stat.s-amber .stat-val { color: var(--amber); }
.stat.s-red .stat-val   { color: var(--red); }
.stat.s-blue .stat-val  { color: var(--blue); }
.stat-sub { font-size: 11px; color: var(--muted); margin-top: 5px; font-family: var(--mono); }

/* ── Section ── */
.sec-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
.sec-title { font-family: var(--display); font-size: 13px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; }

/* ── Today list ── */
.dose-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 28px; }
.dose-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 10px; padding: 14px 16px;
  display: flex; align-items: center; gap: 14px;
}
.dose-time {
  font-family: var(--mono); font-size: 15px; font-weight: 500;
  color: var(--green); min-width: 48px; text-align: center;
  background: var(--green-d); border-radius: 6px; padding: 5px 8px;
}
.dose-med { font-size: 14px; font-weight: 500; color: #fff; }
.dose-pat { font-size: 12px; color: var(--muted); margin-top: 2px; }
.dose-comp { margin-left: auto; font-family: var(--mono); font-size: 11px; color: var(--muted); }

/* ── Table ── */
.tbl-wrap { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
th { text-align: left; padding: 10px 14px; background: var(--bg3); color: var(--muted); font-weight: 500; font-size: 11px; text-transform: uppercase; letter-spacing: .06em; border-bottom: 1px solid var(--border); }
td { padding: 11px 14px; border-bottom: 1px solid var(--border); vertical-align: middle; }
tr:last-child td { border-bottom: none; }
tr:hover td { background: var(--bg3); }
.mono { font-family: var(--mono); font-size: 12px; }

/* ── Badges ── */
.badge {
  display: inline-flex; align-items: center;
  padding: 3px 8px; border-radius: 4px;
  font-size: 11px; font-weight: 500; font-family: var(--mono);
  letter-spacing: .03em;
}
.badge.success      { background: var(--green-d);  color: var(--green); }
.badge.missed       { background: var(--amber-d);  color: var(--amber); }
.badge.wrong_pill   { background: var(--red-d);    color: var(--red); }
.badge.error        { background: var(--red-d);    color: var(--red); }
.badge.custom_named { background: var(--purple-d); color: var(--purple); }
.badge.custom       { background: var(--blue-d);   color: var(--blue); font-size: 10px; padding: 2px 6px; }

/* ── Form ── */
.form-wrap { max-width: 540px; }
.form-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 12px; padding: 24px;
  margin-bottom: 16px;
}
.form-section-title {
  font-family: var(--display); font-size: 14px; font-weight: 600;
  color: #fff; margin-bottom: 18px;
  padding-bottom: 10px; border-bottom: 1px solid var(--border);
}
.field { margin-bottom: 16px; }
.field label {
  display: block; font-size: 11px; font-weight: 500;
  color: var(--muted); text-transform: uppercase;
  letter-spacing: .07em; margin-bottom: 6px;
}
.field input, .field select {
  width: 100%; background: var(--bg);
  border: 1px solid var(--border2);
  border-radius: 7px; color: var(--text);
  padding: 10px 12px; font-size: 13px;
  font-family: var(--sans); outline: none;
  transition: border-color .15s;
}
.field input:focus, .field select:focus { border-color: var(--green); }
.field input::placeholder { color: var(--muted); }
.field select option { background: var(--bg3); }
.row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.hint { font-size: 11px; color: var(--muted); margin-top: 5px; font-family: var(--mono); }

/* ── Day toggles ── */
.days-group { display: flex; gap: 6px; }
.day-btn {
  padding: 6px 11px; border-radius: 6px; font-size: 12px;
  font-family: var(--mono); cursor: pointer;
  border: 1px solid var(--border2);
  background: var(--bg); color: var(--muted);
  transition: all .12s; user-select: none;
}
.day-btn.on { background: var(--green-d); color: var(--green); border-color: var(--green); }

/* ── Custom info box ── */
.info-box {
  background: var(--purple-d); border: 1px solid #2d1f55;
  border-radius: 8px; padding: 12px 14px;
  font-size: 12px; color: var(--purple);
  margin-bottom: 14px; line-height: 1.6;
  display: none;
}
.info-box.show { display: block; }
.custom-fields { display: none; }
.custom-fields.show { display: block; }

/* ── Buttons ── */
.btn {
  display: inline-flex; align-items: center; justify-content: center;
  gap: 6px; padding: 10px 20px; border-radius: 8px;
  font-size: 13px; font-weight: 500; cursor: pointer;
  border: none; transition: all .15s; font-family: var(--sans);
}
.btn-green { background: var(--green); color: #050e0a; }
.btn-green:hover { background: #2bc97a; }
.btn-green:disabled { background: var(--green-d); color: var(--muted); cursor: not-allowed; }
.btn-full { width: 100%; margin-top: 4px; }
.btn-del {
  background: transparent; border: 1px solid var(--red-d);
  color: var(--red); border-radius: 5px;
  padding: 4px 10px; font-size: 11px; cursor: pointer;
  font-family: var(--mono);
}
.btn-del:hover { background: var(--red-d); }

/* ── Toast ── */
.toast {
  position: fixed; bottom: 24px; right: 24px;
  padding: 12px 18px; border-radius: 9px;
  font-size: 13px; font-weight: 500; font-family: var(--mono);
  z-index: 999; display: none;
  animation: toast-in .2s ease;
}
.toast.ok  { background: var(--green-d); color: var(--green); border: 1px solid var(--green); }
.toast.err { background: var(--red-d);   color: var(--red);   border: 1px solid var(--red); }
@keyframes toast-in { from{transform:translateY(8px);opacity:0} to{transform:none;opacity:1} }

.empty { padding: 24px; text-align: center; color: var(--muted); font-size: 13px; font-family: var(--mono); }
</style>
</head>
<body>
<div class="shell">

<!-- Sidebar -->
<aside class="sidebar">
  <div class="logo">
    <div class="logo-mark">
      <div class="logo-icon">💊</div>
      MedSystem
    </div>
    <div class="logo-sub"><span id="dot"></span>ONLINE · RPi 4B</div>
  </div>

  <nav>
    <div class="nav-item active" data-panel="overview" onclick="showPanel(this)">
      <span class="nav-icon">◈</span> Overview
    </div>
    <div class="nav-item" data-panel="alarm" onclick="showPanel(this)">
      <span class="nav-icon">⏰</span> Set Alarm
    </div>
    <div class="nav-item" data-panel="schedule" onclick="showPanel(this)">
      <span class="nav-icon">≡</span> Schedule
    </div>
    <div class="nav-item" data-panel="logs" onclick="showPanel(this)">
      <span class="nav-icon">▤</span> Dispense Log
    </div>
  </nav>

  <div class="sys-info">
    <div class="sys-row"><span>CPU</span><span class="sys-val" id="s-temp">—</span></div>
    <div class="sys-row"><span>Uptime</span><span class="sys-val" id="s-uptime">—</span></div>
    <div class="sys-row"><span>Patients</span><span class="sys-val" id="s-patients">—</span></div>
  </div>
</aside>

<!-- Main -->
<div class="main">
  <div class="topbar">
    <span class="page-title" id="page-title">Overview</span>
    <span id="clock"></span>
  </div>

  <div class="content">

    <!-- OVERVIEW -->
    <div class="panel active" id="panel-overview">
      <div class="cards">
        <div class="stat s-green">
          <div class="stat-lbl">Successful</div>
          <div class="stat-val" id="c-success">—</div>
          <div class="stat-sub" id="c-rate">— success rate</div>
        </div>
        <div class="stat s-amber">
          <div class="stat-lbl">Missed doses</div>
          <div class="stat-val" id="c-missed">—</div>
          <div class="stat-sub">needs follow-up</div>
        </div>
        <div class="stat s-red">
          <div class="stat-lbl">Wrong pill</div>
          <div class="stat-val" id="c-errors">—</div>
          <div class="stat-sub">AI alert</div>
        </div>
        <div class="stat s-blue">
          <div class="stat-lbl">Total dispenses</div>
          <div class="stat-val" id="c-total">—</div>
          <div class="stat-sub">all time</div>
        </div>
      </div>

      <div class="sec-head">
        <span class="sec-title">Today's doses</span>
      </div>
      <div class="dose-list" id="today-list">
        <div class="empty">Loading schedule...</div>
      </div>
    </div>

    <!-- SET ALARM -->
    <div class="panel" id="panel-alarm">
      <div class="form-wrap">
        <div class="form-card">
          <div class="form-section-title">New dispensing alarm</div>

          <div class="field">
            <label>Patient</label>
            <select id="f-patient"></select>
          </div>

          <div class="row2">
            <div class="field">
              <label>Alarm time</label>
              <input type="time" id="f-time" value="08:00">
            </div>
            <div class="field">
              <label>Quantity (pills)</label>
              <input type="number" id="f-qty" value="1" min="1" max="20">
            </div>
          </div>

          <div class="field">
            <label>Days of week</label>
            <div class="days-group">
              <span class="day-btn on" data-d="0">Mon</span>
              <span class="day-btn on" data-d="1">Tue</span>
              <span class="day-btn on" data-d="2">Wed</span>
              <span class="day-btn on" data-d="3">Thu</span>
              <span class="day-btn on" data-d="4">Fri</span>
              <span class="day-btn on" data-d="5">Sat</span>
              <span class="day-btn on" data-d="6">Sun</span>
            </div>
          </div>

          <div class="field">
            <label>Dispensing compartment</label>
            <select id="f-comp">
              <option value="0">Compartment 0 — Morning slot</option>
              <option value="1">Compartment 1 — Noon slot</option>
              <option value="2">Compartment 2 — Evening slot</option>
              <option value="3">Compartment 3 — Night slot</option>
            </select>
          </div>

          <div class="field">
            <label>Medication</label>
            <select id="f-med" onchange="onMedChange()">
              <option value="custom">＋ Custom drug (not in AI model)</option>
            </select>
            <div class="hint">Select a pre-trained drug or enter a custom name below</div>
          </div>
        </div>

        <!-- Custom drug card — shown only when custom selected -->
        <div class="form-card" id="custom-card" style="display:none">
          <div class="form-section-title">Custom drug details</div>

          <div class="info-box show">
            This drug is <strong>not in the AI model's trained classes</strong>.
            The system will record dispensing events under the name you enter here.
            During verification, the AI will accept any detected pill and log it
            as this custom drug — ideal for medications added after model training.
          </div>

          <div class="field">
            <label>Drug name</label>
            <input type="text" id="f-drugname" placeholder="e.g. Lisinopril 10mg">
            <div class="hint">This name appears in all logs and the dashboard</div>
          </div>

          <div class="row2">
            <div class="field">
              <label>Dose (mg)</label>
              <input type="number" id="f-dosemg" placeholder="e.g. 10" min="0">
            </div>
            <div class="field">
              <label>Stock count</label>
              <input type="number" id="f-stock" value="30" min="1">
            </div>
          </div>
        </div>

        <button class="btn btn-green btn-full" id="save-btn" onclick="saveAlarm()">
          Save alarm
        </button>
      </div>
    </div>

    <!-- SCHEDULE -->
    <div class="panel" id="panel-schedule">
      <div class="tbl-wrap">
        <table>
          <thead>
            <tr>
              <th>Time</th><th>Patient</th><th>Medication</th>
              <th>Compartment</th><th>Days</th><th>Qty</th><th></th>
            </tr>
          </thead>
          <tbody id="sched-body">
            <tr><td colspan="7" class="empty">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- LOGS -->
    <div class="panel" id="panel-logs">
      <div class="tbl-wrap">
        <table>
          <thead>
            <tr>
              <th>Timestamp</th><th>Patient</th><th>Expected</th>
              <th>Detected / Used name</th><th>Confidence</th><th>Result</th>
            </tr>
          </thead>
          <tbody id="log-body">
            <tr><td colspan="6" class="empty">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

  </div><!-- content -->
</div><!-- main -->
</div><!-- shell -->

<div class="toast" id="toast"></div>

<script>
const socket = io();
const DAYS = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
const PAGE_TITLES = {overview:'Overview', alarm:'Set Alarm', schedule:'Schedule', logs:'Dispense Log'};

socket.on('connected', () => console.log('MedSystem dashboard live'));
socket.on('new_log',          () => { loadSummary(); loadLogs(); loadToday(); });
socket.on('schedule_updated', () => { loadSchedules(); loadToday(); populateMeds(); });

// Clock
setInterval(() => {
  document.getElementById('clock').textContent =
    new Date().toLocaleTimeString('en-GB', {hour12:false}) + '  ' +
    new Date().toLocaleDateString('en-GB');
}, 1000);

// Panel navigation
function showPanel(el) {
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  const name = el.dataset.panel;
  document.getElementById('panel-'+name).classList.add('active');
  document.getElementById('page-title').textContent = PAGE_TITLES[name];
  if (name === 'alarm')    { populatePatients(); populateMeds(); }
  if (name === 'schedule') loadSchedules();
  if (name === 'logs')     loadLogs();
}

// Day toggle
document.querySelectorAll('.day-btn').forEach(b =>
  b.addEventListener('click', () => b.classList.toggle('on')));
const selectedDays = () =>
  [...document.querySelectorAll('.day-btn.on')].map(b => b.dataset.d).join('');

// Medication selector change
function onMedChange() {
  const isCustom = document.getElementById('f-med').value === 'custom';
  document.getElementById('custom-card').style.display = isCustom ? 'block' : 'none';
}

// API fetch helpers
const api = url => fetch(url).then(r => r.json());

async function populatePatients() {
  const rows = await api('/api/patients');
  const sel  = document.getElementById('f-patient');
  sel.innerHTML = rows.length
    ? rows.map(p => `<option value="${p.id}">${p.name}</option>`).join('')
    : '<option value="">No patients found</option>';
}

async function populateMeds() {
  const rows = await api('/api/medications');
  const sel  = document.getElementById('f-med');
  sel.innerHTML =
    '<option value="custom">＋ Custom drug (not in AI model)</option>' +
    rows.map(m =>
      `<option value="${m.id}">${m.name}${m.custom ? ' ✦ custom' : ''}</option>`
    ).join('');
  onMedChange();
}

async function loadSummary() {
  const d = await api('/api/summary');
  document.getElementById('c-success').textContent  = d.success;
  document.getElementById('c-missed').textContent   = d.missed;
  document.getElementById('c-errors').textContent   = d.errors;
  document.getElementById('c-total').textContent    = d.total;
  document.getElementById('c-rate').textContent     = d.success_rate + '% success rate';
  document.getElementById('s-patients').textContent = d.active_patients;
}

async function loadToday() {
  const rows = await api('/api/schedule/today');
  const el   = document.getElementById('today-list');
  if (!rows.length) {
    el.innerHTML = '<div class="empty">No doses scheduled today</div>';
    return;
  }
  el.innerHTML = rows.map(r => `
    <div class="dose-card">
      <div class="dose-time">${r.time}</div>
      <div>
        <div class="dose-med">
          ${r.med}
          ${r.custom_name ? '<span class="badge custom">custom</span>' : ''}
          &times;${r.qty}
        </div>
        <div class="dose-pat">${r.patient}</div>
      </div>
      <div class="dose-comp">Comp ${r.compartment}</div>
    </div>`).join('');
}

async function loadSchedules() {
  const rows = await api('/api/schedules');
  const tb   = document.getElementById('sched-body');
  if (!rows.length) {
    tb.innerHTML = '<tr><td colspan="7" class="empty">No alarms configured</td></tr>';
    return;
  }
  tb.innerHTML = rows.map(r => {
    const dayStr = [...r.days].map(d => DAYS[+d]).join(', ');
    return `<tr>
      <td class="mono" style="color:var(--green)">${r.time}</td>
      <td>${r.patient}</td>
      <td>${r.med}</td>
      <td class="mono">Comp ${r.comp}</td>
      <td style="font-size:12px;color:var(--muted)">${dayStr}</td>
      <td class="mono">${r.qty}</td>
      <td><button class="btn-del" onclick="delSchedule(${r.id})">Delete</button></td>
    </tr>`;
  }).join('');
}

async function loadLogs() {
  const rows = await api('/api/logs?limit=25');
  const tb   = document.getElementById('log-body');
  if (!rows.length) {
    tb.innerHTML = '<tr><td colspan="6" class="empty">No dispense events yet</td></tr>';
    return;
  }
  tb.innerHTML = rows.map(r => `
    <tr>
      <td class="mono" style="font-size:12px;color:var(--muted)">${r.timestamp}</td>
      <td>${r.patient}</td>
      <td>${r.expected_med}</td>
      <td style="color:var(--muted)">${r.detected_med}</td>
      <td class="mono">${r.confidence !== null ? r.confidence+'%' : '—'}</td>
      <td><span class="badge ${r.outcome}">${r.outcome.replace('_',' ')}</span></td>
    </tr>`).join('');
}

async function loadStatus() {
  const d = await api('/api/status');
  document.getElementById('s-temp').textContent   = d.cpu_temp;
  const up = Math.floor(parseFloat(d.uptime)/3600);
  document.getElementById('s-uptime').textContent = up + 'h';
}

async function delSchedule(id) {
  if (!confirm('Delete this alarm?')) return;
  const d = await fetch('/api/schedule/'+id, {method:'DELETE'}).then(r=>r.json());
  if (d.success) { toast('Alarm deleted'); loadSchedules(); loadToday(); }
}

async function saveAlarm() {
  const btn      = document.getElementById('save-btn');
  const medVal   = document.getElementById('f-med').value;
  const isCustom = medVal === 'custom';
  const days     = selectedDays();

  if (!days)                             { toast('Select at least one day', true); return; }
  if (!document.getElementById('f-patient').value)
                                         { toast('Select a patient', true); return; }
  if (isCustom && !document.getElementById('f-drugname').value.trim())
                                         { toast('Enter a drug name', true); return; }

  const body = {
    patient_id:   +document.getElementById('f-patient').value,
    dose_time:     document.getElementById('f-time').value,
    dose_quantity: +document.getElementById('f-qty').value,
    compartment:   +document.getElementById('f-comp').value,
    days_of_week:  days,
  };

  if (isCustom) {
    body.drug_name   = document.getElementById('f-drugname').value.trim();
    body.dose_mg     = +document.getElementById('f-dosemg').value   || 0;
    body.stock_count = +document.getElementById('f-stock').value    || 30;
  } else {
    body.medication_id = +medVal;
  }

  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const d = await fetch('/api/schedule', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify(body)
    }).then(r => r.json());

    if (d.success) {
      toast(`Alarm set: ${d.medication} at ${d.time}${d.is_custom ? ' (custom drug)' : ''}`);
      document.getElementById('f-drugname').value = '';
      document.getElementById('f-dosemg').value   = '';
      document.getElementById('f-stock').value    = '30';
      loadToday();
    } else {
      toast(d.error || 'Save failed', true);
    }
  } catch { toast('Network error', true); }
  finally { btn.disabled = false; btn.textContent = 'Save alarm'; }
}

function toast(msg, err=false) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className   = 'toast ' + (err ? 'err' : 'ok');
  t.style.display = 'block';
  setTimeout(() => t.style.display = 'none', 3500);
}

// Boot
loadSummary(); loadToday(); loadStatus();
setInterval(loadSummary, 30000);
setInterval(loadToday,   30000);
setInterval(loadStatus,  10000);
</script>
</body>
</html>
